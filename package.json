{
  "name": "instagram-downloader-button",
  "version": "5.0.0",
  "description": "One-click download button per Instagram post. MV3 for Chrome and Firefox.",
  "license": "LGPL-3.0",
  "scripts": {
    "dev": "wxt dev",
    "dev:firefox": "wxt dev -b firefox",
    "build": "wxt build && wxt build -b firefox --mv3",
    "zip": "wxt zip && wxt zip -b firefox --mv3",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "amo-lint": "addons-linter .output/firefox-mv3-zip/*.zip"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "addons-linter": "^6.0.0",
    "web-ext": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.77.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.0",
    "wxt": "^0.19.0"
  }
}
